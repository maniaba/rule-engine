parameters:
	tmpDir: build/phpstan
	level: 5
	paths:
		- src/
		- tests/
	bootstrapFiles:
	excludePaths:
	universalObjectCratesClasses:
	scanDirectories:
	dynamicConstantNames:
		- ENVIRONMENT
	strictRules:
		allRules: false
		disallowedLooseComparison: true
		booleansInConditions: true
		matchingInheritedMethodNames: true
	treatPhpDocTypesAsCertain: false
includes:
